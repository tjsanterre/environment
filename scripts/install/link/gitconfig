[color]
    ui = auto
[user]
    name = Tyler Santerre
    email = tylers@activestate.com
[core]
    editor = vim
    packedGitLimit = 512m
    packedGitWindowSize = 512m
[pack]
    deltaCacheSize = 2047m
    packSizeLimit = 2047m
    windowMemory = 2047m
[pull]
	rebase = true
[push]
	default = current
[status]
	submodulesummary = true
[alias]
    churn = !git log --format=format: --name-only --since="1 year ago" | sort | uniq -c | sort -nr | head -20
    contributors = shortlog -sn --no-merges
    activity = !git log --format='%ad' --date=format:'%Y-%m' | sort | uniq -c
[url "git@github.com:"]
	insteadOf = https://github.com/
[fetch]
	prune = true
